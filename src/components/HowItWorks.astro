---
import Card from './Card.astro'

const steps = [
  {
    num: '01',
    title: 'Recherchez',
    desc: 'Recherche multi-critères ou par image (IA) parmi 300 fournisseurs européens et 1M+ produits, dans un seul catalogue.',
    delay: '0.05s',
  },
  {
    num: '02',
    title: 'Comparez',
    desc: 'Prix, MOQ, délais et certifications côte à côte — instantanément, sans feuilleter cent catalogues.',
    delay: '0.14s',
  },
  {
    num: '03',
    title: 'Commandez',
    desc: 'Demande de devis en un clic, réponse sous 24 h. Sans abonnement obligatoire, jamais.',
    delay: '0.23s',
  },
]
---

<section id="fonctionnement" class="wrapper py-24">
	<div class="mb-12 text-center">
		<p class="mb-6 text-eyebrow text-text-brand">Comment ça marche</p>
		<h2 class="mb-3 text-display-md">Du besoin au devis en trois étapes</h2>
		<p class="text-body-md text-text-secondary">Le sourcing d'objets publicitaires, enfin simple.</p>
	</div>

	<div data-reveal class="grid gap-6 md:grid-cols-3">
		{
			steps.map((step) => (
				<Card class="p-8">
					<span
						data-pop
						style={`transition-delay: ${step.delay};`}
						class="text-tabular text-stat-figure block text-indigo-600"
					>
						{step.num}
					</span>
					<h3 class="mb-2 mt-5 text-heading-md text-text-primary">{step.title}</h3>
					<p class="text-body-md text-text-muted">{step.desc}</p>
				</Card>
			))
		}
	</div>
</section>
