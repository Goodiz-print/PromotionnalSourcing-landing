---
import Card from './Card.astro'
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const steps = [
  {
    num: '01',
    title: t('howItWorks.step1Title'),
    desc: t('howItWorks.step1Desc'),
    delay: '0.05s',
  },
  {
    num: '02',
    title: t('howItWorks.step2Title'),
    desc: t('howItWorks.step2Desc'),
    delay: '0.14s',
  },
  {
    num: '03',
    title: t('howItWorks.step3Title'),
    desc: t('howItWorks.step3Desc'),
    delay: '0.23s',
  },
]
---

<section id="fonctionnement" class="wrapper py-24">
	<div class="mb-12 text-center">
		<p class="mb-6 text-eyebrow text-text-brand">{t('howItWorks.eyebrow')}</p>
		<h2 class="mb-3 text-display-md">{t('howItWorks.heading')}</h2>
		<p class="text-body-md text-text-secondary">{t('howItWorks.subheading')}</p>
	</div>

	<div data-reveal class="grid gap-6 md:grid-cols-3">
		{
			steps.map((step) => (
				<Card class="p-8">
					<span
						data-pop
						style={`transition-delay: ${step.delay};`}
						class="text-tabular text-stat-figure block text-indigo-600"
					>
						{step.num}
					</span>
					<h3 class="mb-2 mt-5 text-heading-md text-text-primary">{step.title}</h3>
					<p class="text-body-md text-text-muted">{step.desc}</p>
				</Card>
			))
		}
	</div>
</section>
