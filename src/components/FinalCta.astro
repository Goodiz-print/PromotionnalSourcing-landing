---
import Button from './Button.astro'
---

<section id="contact" class="bg-indigo-500 px-6 py-[88px] text-center md:px-10">
	<div data-reveal>
		<h2 class="mx-auto mb-4 max-w-[640px] text-display-lg text-white">
			Devenez le réflexe n°1 des acheteurs européens.
		</h2>
		<p class="mb-9 text-body-lg text-indigo-100">
			Rejoignez les premiers fournisseurs et agences du réseau européen du sourcing publicitaire.
		</p>
		<Button href="mailto:contact@promotionalsourcing.eu" variant="on-dark">Nous contacter</Button>
	</div>
</section>
