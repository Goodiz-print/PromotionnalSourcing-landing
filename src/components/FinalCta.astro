---
import Button from './Button.astro'
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)
---

<section id="contact" class="bg-indigo-500 px-6 py-[88px] text-center md:px-10">
	<div data-reveal>
		<h2 class="mx-auto mb-4 max-w-[640px] text-display-lg text-white">
			{t('finalCta.heading')}
		</h2>
		<p class="mb-9 text-body-lg text-indigo-100">
			{t('finalCta.description')}
		</p>
		<Button href="mailto:contact@promotionalsourcing.eu" variant="on-dark">{t('finalCta.cta')}</Button>
	</div>
</section>
