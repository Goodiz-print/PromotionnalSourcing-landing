---
const productLinks = [
  { label: 'Catalogue', href: '#fonctionnalites' },
  { label: 'Recherche par image', href: '#fonctionnalites' },
  { label: 'Demande de devis', href: '#fonctionnalites' },
  { label: 'Tarifs', href: '#tarifs' },
]

const companyLinks = [{ label: 'Fournisseurs', href: '#fournisseurs' }]

const resourceLinks = [{ label: 'Contact', href: 'mailto:contact@promotionalsourcing.eu' }]

const columns = [
  { title: 'Produit', links: productLinks },
  { title: 'Entreprise', links: companyLinks },
  { title: 'Ressources', links: resourceLinks },
]
---

<footer class="wrapper py-16">
	<div class="mb-12 grid grid-cols-1 gap-8 sm:grid-cols-[1.4fr_repeat(3,1fr)]">
		<div>
			<img src="/logo.png" alt="promotionalsourcing.eu" width="776" height="310" class="mb-3 h-6 w-auto" />
			<p class="max-w-[220px] text-caption text-text-muted">
				La plateforme de sourcing B2B pour les objets publicitaires en Europe.
			</p>
		</div>
		{
			columns.map((column) => (
				<div>
					<p class="mb-3.5 text-caption font-bold text-text-primary">{column.title}</p>
					{column.links.map((link) => (
						<a href={link.href} class="block py-1.5 text-caption text-text-muted hover:text-text-primary">
							{link.label}
						</a>
					))}
				</div>
			))
		}
	</div>
	<div class="flex flex-wrap justify-between gap-2 border-t border-hairline pt-6 text-caption text-text-muted">
		<span>© 2026 Promotional Sourcing.eu</span>
		<span>Fait pour les acheteurs et fournisseurs européens</span>
	</div>
</footer>
