---
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const productLinks = [
  { label: t('footer.linkCatalogue'), href: '#fonctionnalites' },
  { label: t('footer.linkImageSearch'), href: '#fonctionnalites' },
]

const companyLinks = [{ label: t('footer.linkSuppliers'), href: '#fournisseurs' }]

const resourceLinks = [{ label: t('footer.linkContact'), href: 'mailto:contact@promotionalsourcing.eu' }]

const columns = [
  { title: t('footer.columnProduct'), links: productLinks },
  { title: t('footer.columnCompany'), links: companyLinks },
  { title: t('footer.columnResources'), links: resourceLinks },
]
---

<footer class="wrapper py-16">
	<div class="mb-12 grid grid-cols-1 gap-8 sm:grid-cols-[1.4fr_repeat(3,1fr)]">
		<div>
			<img src="/logo.png" alt="promotionalsourcing.eu" width="776" height="310" class="mb-3 h-6 w-auto" />
			<p class="max-w-[220px] text-caption text-text-muted">
				{t('footer.tagline')}
			</p>
		</div>
		{
			columns.map((column) => (
				<div>
					<p class="mb-3.5 text-caption font-bold text-text-primary">{column.title}</p>
					{column.links.map((link) => (
						<a href={link.href} class="block py-1.5 text-caption text-text-muted hover:text-text-primary">
							{link.label}
						</a>
					))}
				</div>
			))
		}
	</div>
	<div class="flex flex-wrap justify-between gap-2 border-t border-hairline pt-6 text-caption text-text-muted">
		<span>{t('footer.copyright')}</span>
		<span>{t('footer.madeFor')}</span>
	</div>
</footer>
