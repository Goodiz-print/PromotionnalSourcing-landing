---
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const platformLinks = [
  { label: t('footer.linkAgencies'), href: '#agences' },
  { label: t('footer.linkSuppliers'), href: '#fournisseurs' },
  { label: t('footer.linkContact'), href: '#contact' },
]

const legalLinks = [
  { label: t('footer.linkLegalMentions'), href: '#' },
  { label: t('footer.linkPrivacy'), href: '#' },
]

const columns = [
  { title: t('footer.columnPlatform'), links: platformLinks },
  { title: t('footer.columnLegal'), links: legalLinks },
]
---

<footer class="wrapper py-16">
	<div class="mb-12 flex flex-wrap justify-between gap-10">
		<div>
			<img src="/logo.png" alt="promotionalsourcing.eu" width="776" height="310" class="mb-3 h-9 w-auto" />
			<p class="text-caption text-text-muted">{t('footer.location')}</p>
		</div>
		<div class="flex flex-wrap gap-14">
			{
				columns.map((column) => (
					<div>
						<p class="mb-3.5 text-caption font-bold text-text-primary">{column.title}</p>
						{column.links.map((link) => (
							<a href={link.href} class="block py-1.5 text-caption text-text-muted hover:text-text-primary">
								{link.label}
							</a>
						))}
					</div>
				))
			}
		</div>
	</div>
	<div class="flex flex-wrap justify-between gap-2 border-t border-hairline pt-6 text-caption text-text-muted">
		<span>{t('footer.copyright')}</span>
		<span class="inline-flex items-center gap-2 font-semibold">
			<span class="inline-block h-2.5 w-2.5 rounded-full" style="background: var(--gradient-brand);" />
			{t('footer.domain')}
		</span>
	</div>
</footer>
