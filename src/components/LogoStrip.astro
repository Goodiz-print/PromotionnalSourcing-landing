---
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const suppliers = ['EcoBag Fabrics', 'Jute & Co', 'Greenweave', 'NW Textiles', 'Recyfil', 'PlumaPress', 'Nordic Print', 'Textilia Iberia']
const track = [...suppliers, ...suppliers]
---

<section data-reveal class="wrapper py-20 sm:py-24">
	<p class="mb-7 text-center text-eyebrow text-text-muted">
		{t('logoStrip.eyebrow')}
	</p>
	<div
		class="relative overflow-hidden"
		style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);"
	>
		<div class="anim-marquee flex w-max gap-3.5">
			{
				track.map((supplier) => (
					<span class="shrink-0 whitespace-nowrap rounded-md border border-hairline px-[22px] py-2.5 text-body-md font-semibold text-ink-400 transition-colors duration-150 hover:border-indigo-300 hover:text-indigo-600">
						{supplier}
					</span>
				))
			}
		</div>
	</div>
</section>
