---
import Card from './Card.astro'
import Button from './Button.astro'
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const agencyPoints = t('audience.agency.points')
const supplierPoints = t('audience.supplier.points')
---

<section id="fournisseurs" class="wrapper py-24">
	<div data-reveal class="mx-auto mb-12 max-w-[640px] text-center">
		<p class="mb-4 text-eyebrow text-text-brand">{t('audience.eyebrow')}</p>
		<h2 class="text-display-lg">{t('audience.heading')}</h2>
	</div>

	<div class="grid gap-6 md:grid-cols-2">
		<Card data-reveal hover class="flex flex-col p-8">
			<p class="mb-2 text-eyebrow text-text-muted">{t('audience.agency.eyebrow')}</p>
			<h3 class="mb-4 text-heading-lg">{t('audience.agency.heading')}</h3>
			<ul class="mb-6 flex flex-1 flex-col gap-2.5">
				{
					agencyPoints.map((point) => (
						<li class="flex gap-2 text-body-md text-text-secondary">
							<span class="text-indigo-500">✓</span>
							<span>{point}</span>
						</li>
					))
				}
			</ul>
			<a class="inline-flex items-center gap-2 text-body-md font-semibold text-indigo-600" href="#fonctionnalites">
				{t('audience.agency.cta')} <span aria-hidden="true">→</span>
			</a>
		</Card>

		<Card data-reveal hover variant="brand" class="relative flex flex-col overflow-hidden p-8" style="transition-delay: 0.08s; background: var(--gradient-brand);">
			<canvas data-canvas="nodes" class="pointer-events-none absolute inset-0 block h-full w-full opacity-60"></canvas>
			<div class="relative z-10 flex flex-1 flex-col">
				<p class="mb-2 text-eyebrow text-indigo-100">{t('audience.supplier.eyebrow')}</p>
				<h3 class="mb-4 text-heading-lg text-white">{t('audience.supplier.heading')}</h3>
				<ul class="mb-6 flex flex-1 flex-col gap-2.5">
					{
						supplierPoints.map((point) => (
							<li class="flex gap-2 text-body-md text-white">
								<span>✓</span>
								<span>{point}</span>
							</li>
						))
					}
				</ul>
				<Button href="mailto:contact@promotionalsourcing.eu" variant="on-dark" class="self-start">
					{t('audience.supplier.cta')}
				</Button>
			</div>
		</Card>
	</div>
</section>
