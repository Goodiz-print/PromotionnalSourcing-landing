---
import Button from './Button.astro'

const navItems = [
  { label: 'Catalogue' },
  { label: 'Fournisseurs' },
  { label: 'Tarifs', href: '#tarifs' },
  { label: 'Ressources' },
]
---

<header data-nav class="sticky top-0 z-50 flex h-[76px] items-center justify-between border-b border-hairline px-6 backdrop-blur-md md:px-10">
	<div class="flex items-center gap-11">
		<a href="/" class="shrink-0">
			<img src="/logo.png" alt="promotionalsourcing.eu" width="776" height="310" class="h-[26px] w-auto" />
		</a>
		<nav class="hidden items-center gap-7 text-body-sm font-medium text-text-secondary md:flex">
			{
				navItems.map((item) =>
					item.href ? (
						<a href={item.href} class="nav-link">
							{item.label}
						</a>
					) : (
						<span class="nav-link">{item.label}</span>
					)
				)
			}
		</nav>
	</div>
	<div class="flex items-center gap-2.5">
		<Button href="#waitlist" class="!px-5 !py-2.5 text-body-sm">Liste d'attente</Button>
	</div>
</header>
