---
import Button from './Button.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const navItems = [
  { label: t('nav.agences'), href: '#agences' },
  { label: t('nav.fournisseurs'), href: '#fournisseurs' },
  { label: t('nav.contact'), href: '#contact' },
]

const currentLocale = Astro.currentLocale ?? 'fr'
const otherLocale = currentLocale === 'fr' ? 'en' : 'fr'
const otherLocaleHref = getRelativeLocaleUrl(otherLocale, '/')
---

<header data-nav class="sticky top-0 z-50 border-b border-hairline backdrop-blur-md">
	<div class="flex h-[76px] items-center justify-between px-6 md:px-10">
		<div class="flex items-center gap-11">
			<a href="/" class="shrink-0">
				<img src="/logo.png" alt="promotionalsourcing.eu" width="776" height="310" class="h-12 w-auto" />
			</a>
			<nav class="hidden items-center gap-7 text-body-sm font-bold text-text-secondary md:flex">
				{
					navItems.map((item) => (
						<a href={item.href} class="nav-link">
							{item.label}
						</a>
					))
				}
			</nav>
		</div>
		<div class="flex items-center gap-3">
			<a
				href={otherLocaleHref}
				hreflang={otherLocale}
				class="hidden items-center gap-1.5 rounded-pill border border-hairline px-3 py-1.5 text-caption font-semibold text-text-secondary transition-colors duration-150 hover:border-indigo-300 hover:text-indigo-600 md:inline-flex"
			>
				<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" />
					<path d="M1.5 8h13M8 1.5c1.8 1.8 2.8 4.1 2.8 6.5s-1 4.7-2.8 6.5c-1.8-1.8-2.8-4.1-2.8-6.5s1-4.7 2.8-6.5Z" stroke="currentColor" stroke-width="1.3" />
				</svg>
				{t('nav.switchTo')}
			</a>
			<span
				class="hidden cursor-not-allowed items-center gap-2 rounded-pill border border-hairline bg-sunken px-4 py-1.5 text-caption font-semibold text-ink-300 md:inline-flex"
				title={t('nav.loginTitle')}
				aria-disabled="true"
			>
				{t('nav.login')}
				<span class="rounded-pill bg-yellow-400 px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wide text-ink-950">{t('nav.soon')}</span>
			</span>
			<div class="hidden md:block">
				<Button href="#contact" class="!px-5 !py-2.5 text-body-sm">{t('nav.cta')}</Button>
			</div>
			<button
				type="button"
				data-menu-toggle
				aria-expanded="false"
				aria-controls="mobile-nav"
				aria-label={t('nav.menuAria')}
				class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-text-primary md:hidden"
			>
				<svg data-menu-icon-open width="20" height="20" viewBox="0 0 20 20" fill="none">
					<path d="M2.5 5.5h15M2.5 10h15M2.5 14.5h15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
				</svg>
				<svg data-menu-icon-close class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none">
					<path d="M4.5 4.5l11 11M15.5 4.5l-11 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
				</svg>
			</button>
		</div>
	</div>
	<nav id="mobile-nav" data-mobile-nav hidden class="flex flex-col gap-1 border-t border-hairline px-6 pb-6 pt-3 md:hidden">
		{
			navItems.map((item) => (
				<a href={item.href} data-mobile-nav-link class="rounded-md px-2 py-3 text-body-md font-bold text-text-primary">
					{item.label}
				</a>
			))
		}
		<Button href="#contact" data-mobile-nav-link class="mt-3 w-full text-center">{t('nav.cta')}</Button>
		<a
			href={otherLocaleHref}
			hreflang={otherLocale}
			data-mobile-nav-link
			class="mt-1 inline-flex items-center gap-1.5 self-center rounded-pill border border-hairline px-3.5 py-2 text-body-sm font-semibold text-text-secondary"
		>
			<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
				<circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" />
				<path d="M1.5 8h13M8 1.5c1.8 1.8 2.8 4.1 2.8 6.5s-1 4.7-2.8 6.5c-1.8-1.8-2.8-4.1-2.8-6.5s1-4.7 2.8-6.5Z" stroke="currentColor" stroke-width="1.3" />
			</svg>
			{t('nav.switchTo')}
		</a>
		<span
			class="mt-3 inline-flex cursor-not-allowed items-center gap-2 self-center rounded-pill border border-hairline bg-sunken px-4 py-1.5 text-caption font-semibold text-ink-300"
			title={t('nav.loginTitle')}
			aria-disabled="true"
		>
			{t('nav.login')}
			<span class="rounded-pill bg-yellow-400 px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wide text-ink-950">{t('nav.soon')}</span>
		</span>
	</nav>
</header>

<script>
	const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]')
	const menu = document.querySelector<HTMLElement>('[data-mobile-nav]')
	const iconOpen = document.querySelector('[data-menu-icon-open]')
	const iconClose = document.querySelector('[data-menu-icon-close]')

	function setOpen(open: boolean) {
		if (!toggle || !menu) return
		menu.hidden = !open
		toggle.setAttribute('aria-expanded', String(open))
		iconOpen?.classList.toggle('hidden', open)
		iconClose?.classList.toggle('hidden', !open)
		document.body.classList.toggle('overflow-hidden', open)
	}

	toggle?.addEventListener('click', () => setOpen(Boolean(menu?.hidden)))
	menu?.querySelectorAll('[data-mobile-nav-link]').forEach((link) => link.addEventListener('click', () => setOpen(false)))
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && menu && !menu.hidden) setOpen(false)
	})
</script>
