---
interface Props {
  class?: string
}

const { class: className = '' } = Astro.props
---

<div
	aria-hidden="true"
	class={`anim-mesh pointer-events-none absolute inset-[-10%] z-0 ${className}`}
	style="background: radial-gradient(480px 320px at 18% 20%, rgba(64,50,200,0.16), transparent 60%), radial-gradient(520px 360px at 82% 10%, rgba(246,166,35,0.10), transparent 60%), radial-gradient(600px 400px at 50% 0%, rgba(64,50,200,0.07), transparent 65%);"
></div>
