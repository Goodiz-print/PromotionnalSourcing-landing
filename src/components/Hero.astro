---
import Button from './Button.astro'
import GradientMesh from './GradientMesh.astro'
import ProductMockup from './ProductMockup.astro'

const dots = ['Recherche par image (IA)', 'Fournisseurs vérifiés', 'Catalogue européen']
---

<section class="relative overflow-hidden px-6 pb-[72px] pt-[108px] text-center md:px-10">
	<GradientMesh />

	<canvas data-canvas="hero" class="pointer-events-none absolute inset-0 z-0 block h-full w-full" aria-hidden="true"></canvas>

	<div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 z-0 h-[170px] overflow-hidden leading-[0]">
		<div class="anim-wave absolute -bottom-4 left-0 h-full w-[200%]">
			<svg viewBox="0 0 2880 320" preserveAspectRatio="none" class="block h-full w-full">
				<path
					d="M0,180 C120,140 240,220 360,180 C480,140 600,220 720,180 C840,140 960,220 1080,180 C1200,140 1320,220 1440,180 C1560,140 1680,220 1800,180 C1920,140 2040,220 2160,180 C2280,140 2400,220 2520,180 C2640,140 2760,220 2880,180 L2880,320 L0,320 Z"
					fill="var(--indigo-500)"
					opacity="0.07"></path>
			</svg>
		</div>
		<div class="anim-wave-reverse absolute -bottom-2 left-0 h-full w-[200%]">
			<svg viewBox="0 0 2880 320" preserveAspectRatio="none" class="block h-full w-full">
				<path
					d="M0,210 C120,180 240,240 360,210 C480,180 600,240 720,210 C840,180 960,240 1080,210 C1200,180 1320,240 1440,210 C1560,180 1680,240 1800,210 C1920,180 2040,240 2160,210 C2280,180 2400,240 2520,210 C2640,180 2760,240 2880,210 L2880,320 L0,320 Z"
					fill="var(--indigo-500)"
					opacity="0.12"></path>
			</svg>
		</div>
	</div>

	<div class="relative mx-auto max-w-[780px]">
		<div class="anim-rise mb-7 inline-flex items-center gap-2 rounded-pill bg-brand-subtle px-4 py-1.5 text-caption font-semibold text-indigo-600">
			<span class="anim-pulse-dot inline-block h-2 w-2 rounded-full bg-orange-500" aria-hidden="true"></span>
			300 fournisseurs européens · 1M+ produits
		</div>
		<h1 class="anim-rise mx-auto mb-6 text-display-lg sm:text-display-xl" style="animation-delay: 0.06s;">
			Le sourcing d'objets<br />publicitaires, <span class="text-gradient-brand">simplifié</span>.
		</h1>
		<p class="anim-rise mx-auto mb-10 max-w-[560px] text-body-lg text-text-secondary" style="animation-delay: 0.12s;">
			Recherche intelligente, comparaison instantanée, mise en relation directe — fini les cent
			catalogues à feuilleter.
		</p>

		<div class="anim-rise mb-5 flex flex-wrap justify-center gap-3" style="animation-delay: 0.18s;">
			<Button href="#contact">Nous contacter</Button>
			<Button href="#fonctionnalites" variant="secondary">Voir le catalogue</Button>
		</div>

		<div class="anim-rise flex flex-wrap justify-center gap-2.5 text-caption text-text-muted" style="animation-delay: 0.22s;">
			{
				dots.map((dot) => (
					<span class="inline-flex items-center gap-1.5">
						<span class="inline-block h-1.5 w-1.5 rounded-full bg-indigo-500" />
						{dot}
					</span>
				))
			}
		</div>
	</div>

	<div class="relative mt-14">
		<ProductMockup />
	</div>
</section>
