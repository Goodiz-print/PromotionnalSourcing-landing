---
import { Image } from 'astro:assets'
import Card from './Card.astro'
import sacCoton from '../assets/images/CGB2601_PHOTO_0.jpg'
import toteBag from '../assets/images/impr_1458560-PDP_25.webp'
import mockToteBag from '../assets/images/mock-tote-bag.jpg'

const searchResults = [
	{ name: 'Sac shopping coton 220g', variant: 'Naturel · 220 g/m²', price: '1,24 €', image: sacCoton },
	{ name: 'Sac shopping jute imprimé', variant: 'Jute · 350 g/m²', price: '0,98 €', image: toteBag },
]

const chartLegend = [
	{ label: 'Recyfil', price: '0,98 €', color: 'bg-indigo-500', textClass: 'text-indigo-600' },
	{ label: 'EcoBag', price: '1,24 €', color: 'bg-ink-300' },
	{ label: 'Jute&Co', price: '1,89 €', color: 'bg-ink-200' },
]
---

<section id="fonctionnalites" class="wrapper py-24">
	<div data-reveal class="mx-auto mb-16 max-w-[640px] text-center">
		<p class="mb-4 text-eyebrow text-text-brand">La solution</p>
		<h2 class="text-display-lg">Une plateforme unique pour tout le sourcing européen.</h2>
	</div>

	<div class="grid grid-cols-2 gap-4 md:grid-cols-6">
		<!-- Recherche intelligente -->
		<Card data-reveal hover class="group col-span-2 flex flex-col p-7 md:col-span-3">
			<p class="mb-2 text-heading-lg">Recherche intelligente</p>
			<p class="mb-5 text-body-md text-text-secondary">
				Filtrez par matière, grammage, pays de fabrication ou certification — le bon produit en secondes, pas en heures.
			</p>
			<div class="relative flex-1 overflow-hidden rounded-md border border-hairline bg-sunken p-[18px]">
				<canvas data-canvas="search-field" class="pointer-events-none absolute inset-0 block h-full w-full"></canvas>
				<div class="relative z-10 flex h-full flex-col gap-2.5">
					<div class="flex items-center gap-2 self-start rounded-[14px] rounded-bl-[4px] border border-indigo-300 bg-white px-3.5 py-2.5 shadow-[0_0_0_3px_var(--surface-brand-subtle)]">
						<span class="text-body-sm font-medium text-text-primary">sac shopping made in europe +200 g/m²</span>
						<span class="anim-caret h-[15px] w-0.5 bg-indigo-500"></span>
					</div>
					<div class="self-start max-w-[92%] rounded-[14px] rounded-bl-[4px] bg-brand-subtle px-3.5 py-2.5 text-body-sm font-medium text-indigo-600">
						2 correspondances parmi 300+ fournisseurs vérifiés
					</div>
					<div class="mt-0.5 grid grid-cols-2 gap-2.5">
						{
							searchResults.map((result) => (
								<div class="bento-product-card flex flex-col gap-1 rounded-sm border border-hairline bg-white p-2.5 shadow-elevation-1">
									<div class="mb-0.5 flex aspect-[3/4] items-center justify-center overflow-hidden rounded-sm bg-sunken">
										<Image src={result.image} alt={result.name} width={300} height={400} class="h-full w-full object-contain" />
									</div>
									<span class="text-body-sm font-semibold leading-tight">{result.name}</span>
									<span class="text-[11px] text-text-muted">{result.variant}</span>
									<span class="text-tabular text-body-sm font-semibold text-indigo-600">{result.price}</span>
								</div>
							))
						}
					</div>
					<span class="bento-match mt-0.5 inline-flex items-center gap-1.5 self-center rounded-pill bg-ink-950 px-3.5 py-1.5 text-[12px] font-bold text-white">
						✓ Comparaison prête en 1 clic
					</span>
				</div>
			</div>
			<p class="mt-[18px] text-body-sm font-semibold text-indigo-600">
				Explorer le catalogue <span class="bento-arrow">→</span>
			</p>
		</Card>

		<!-- Recherche par image IA -->
		<Card data-reveal hover variant="brand" class="group col-span-2 flex flex-col p-7 md:col-span-3" style="transition-delay: 0.05s;">
			<p class="mb-2 text-heading-lg text-white">Recherche par image (IA)</p>
			<p class="mb-5 text-body-md text-indigo-100">
				Déposez la photo du produit que cherche votre client — l'IA retrouve l'équivalent le plus proche parmi 1M+ références.
			</p>
			<div class="relative flex min-h-[190px] flex-1 flex-col items-center justify-center gap-3 overflow-hidden rounded-md border border-dashed border-white/40 bg-white/[0.07]">
				<canvas data-canvas="scan" class="absolute inset-0 block h-full w-full"></canvas>
				<div
					class="anim-scan-line absolute left-[6%] right-[6%] h-0.5"
					style="background: linear-gradient(90deg, transparent, #fff, transparent); box-shadow: 0 0 14px rgba(255,255,255,0.9);"
				>
				</div>
				<div class="relative h-[176px] w-[176px] overflow-hidden rounded-md border border-white/25 bg-white/[0.14]">
					<Image src={mockToteBag} alt="Photo déposée par l'utilisateur" width={176} height={176} class="h-full w-full object-cover" />
				</div>
				<p class="relative text-body-sm font-medium text-indigo-100">Glissez une photo ici</p>
				<div class="bento-match relative inline-flex items-center gap-2 rounded-pill bg-white px-3.5 py-1.5 text-[12px] font-bold text-indigo-600">
					<span class="text-tabular">✓ Correspondance 98 % — Sac coton 220g</span>
				</div>
			</div>
			<p class="mt-[18px] text-body-sm font-semibold text-white">
				Essayer la recherche IA <span class="bento-arrow">→</span>
			</p>
		</Card>

		<!-- Comparaison instantanée -->
		<Card data-reveal hover class="group col-span-2 flex flex-col p-6" style="transition-delay: 0.1s;">
			<p class="mb-1.5 text-heading-md">Comparaison instantanée</p>
			<p class="mb-4 text-body-sm text-text-secondary">Prix et MOQ de tous les fournisseurs, côte à côte.</p>
			<div class="relative min-h-[96px] flex-1">
				<canvas data-canvas="chart" class="absolute inset-0 block h-full w-full"></canvas>
			</div>
			<div class="mt-2.5 flex flex-wrap gap-3.5">
				{
					chartLegend.map((item) => (
						<span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-text-muted">
							<span class={`inline-block h-2 w-2 rounded-full ${item.color}`} />
							{item.label} · <span class={`text-tabular ${item.textClass ?? ''}`}>{item.price}</span>
						</span>
					))
				}
			</div>
			<p class="mt-4 text-caption font-semibold text-indigo-600">
				Comparer <span class="bento-arrow">→</span>
			</p>
		</Card>

		<!-- Devis en un clic -->
		<Card data-reveal hover class="group col-span-2 flex flex-col p-6" style="transition-delay: 0.15s;">
			<p class="mb-1.5 text-heading-md">Devis en un clic</p>
			<p class="mb-3 text-body-sm text-text-secondary">Une demande, tous les fournisseurs concernés.</p>
			<p class="mb-2 text-caption font-semibold text-text-muted">Sac coton · 5 000 pcs</p>
			<div class="relative flex min-h-[96px] flex-1 items-center justify-center overflow-hidden rounded-md">
				<canvas data-canvas="quote-broadcast" class="pointer-events-none absolute inset-0 z-0 block h-full w-full"></canvas>
				<span class="bento-state-a absolute rounded-pill bg-indigo-500 px-6 py-2.75 text-caption font-semibold text-white">
					Demander un devis
				</span>
				<span class="bento-state-b absolute flex flex-col items-center gap-2">
					<span class="flex -space-x-2">
						<span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-white bg-indigo-100 text-[10px] font-bold text-indigo-600 shadow-elevation-1">EB</span>
						<span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-white bg-brand-subtle text-[10px] font-bold text-indigo-600 shadow-elevation-1">NP</span>
						<span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-white bg-ink-100 text-[10px] font-bold text-ink-600 shadow-elevation-1">GW</span>
					</span>
					<span class="inline-flex items-center gap-1.5 rounded-pill bg-success-bg px-3.5 py-1.5 text-caption font-bold text-success">
						✓ Envoyé à 3 fournisseurs
					</span>
				</span>
			</div>
			<p class="mt-4 text-caption font-semibold text-indigo-600">
				Voir comment <span class="bento-arrow">→</span>
			</p>
		</Card>

		<!-- Fournisseurs vérifiés + sans abonnement -->
		<Card data-reveal hover variant="dark" class="col-span-2 flex flex-col p-6" style="transition-delay: 0.2s;">
			<p class="text-tabular text-[28px] font-semibold text-white">300+</p>
			<p class="mb-3 text-caption text-ink-300">Fournisseurs européens vérifiés</p>
			<div class="relative -mx-1.5 min-h-[96px] flex-1">
				<canvas data-canvas="nodes" class="absolute inset-0 block h-full w-full"></canvas>
			</div>
			<div class="mt-3 flex items-baseline justify-between">
				<span class="text-caption text-ink-300">Sans abonnement obligatoire</span>
				<span class="text-tabular text-heading-md text-white">0 €</span>
			</div>
		</Card>
	</div>
</section>
