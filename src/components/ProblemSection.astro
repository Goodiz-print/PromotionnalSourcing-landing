---
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)
---

<section id="probleme" class="bg-sunken px-6 py-24 md:px-10">
	<div data-reveal class="mx-auto max-w-[880px] text-center">
		<p class="mb-6 text-eyebrow text-text-brand">{t('problem.eyebrow')}</p>
		<p class="text-display-md text-text-primary">
			{t('problem.quote')}
		</p>
		<p class="mt-6 text-body-md text-text-muted">
			{t('problem.closing')}
		</p>
	</div>
</section>
