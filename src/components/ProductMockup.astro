---
import { Image } from 'astro:assets'
import sacCoton from '../assets/images/sac-coton.webp'
import sacJute from '../assets/images/sac-jute.webp'
import toteBag from '../assets/images/tote-bag-2.webp'

const tags = ['Made in Europe', '+200 g/m²', 'Coton']

const products = [
  { name: 'Sac shopping coton 220g', verified: true, supplier: 'EcoBag Fabrics', price: '1,24 €', moq: '500', image: sacCoton },
  { name: 'Sac shopping jute naturel', verified: true, supplier: 'Jute & Co', price: '1,89 €', moq: '250', image: sacJute },
  { name: 'Sac shopping toile recyclée', verified: false, supplier: 'Recyfil', price: '0,98 €', moq: '1 000', image: toteBag },
]
---

<div
	data-reveal
	class="anim-float relative mx-auto max-w-[880px] overflow-hidden rounded-xl border border-hairline bg-card text-left shadow-elevation-3"
	role="img"
	aria-label="Aperçu de la recherche promotionalsourcing.eu/recherche : trois sacs shopping filtrés par Made in Europe, +200 g/m² et coton, avec fournisseur, prix et quantité minimale de commande."
>
	<div aria-hidden="true">
		<div class="flex items-center gap-1.5 border-b border-hairline bg-sunken px-[18px] py-3.5">
			<span class="h-[9px] w-[9px] rounded-full bg-ink-200"></span>
			<span class="h-[9px] w-[9px] rounded-full bg-ink-200"></span>
			<span class="h-[9px] w-[9px] rounded-full bg-ink-200"></span>
			<span class="ml-3 text-caption text-text-muted">promotionalsourcing.eu/recherche</span>
		</div>
		<div class="px-6 py-5">
			<div class="mb-4 flex flex-wrap gap-2">
				{
					tags.map((tag, i) => (
						<span
							class={`rounded-pill px-[11px] py-[5px] text-caption font-semibold ${i === 0 ? 'bg-brand-subtle text-indigo-600' : 'bg-ink-100 text-ink-600'}`}
						>
							{tag}
						</span>
					))
				}
			</div>
			<div class="grid grid-cols-[28px_minmax(0,1fr)_64px_54px] items-center gap-2 border-b border-hairline py-2.5 text-caption font-bold uppercase tracking-wide text-text-muted sm:grid-cols-[40px_minmax(0,1fr)_110px_90px_80px] sm:gap-3">
				<div></div>
				<div>Produit</div>
				<div class="hidden sm:block">Fournisseur</div>
				<div class="text-right">Prix</div>
				<div class="text-right">MOQ</div>
			</div>
			{
				products.map((product, i) => (
					<div
						class={`grid grid-cols-[28px_minmax(0,1fr)_64px_54px] items-center gap-2 py-3 sm:grid-cols-[40px_minmax(0,1fr)_110px_90px_80px] sm:gap-3 ${i < products.length - 1 ? 'border-b border-hairline' : ''}`}
					>
						<Image src={product.image} alt={product.name} width={32} height={32} class="h-8 w-8 rounded-sm object-cover" />
						<div class="min-w-0 text-body-sm font-semibold text-text-primary">
							{product.name}
							{product.verified && (
								<span class="ml-1.5 rounded-pill bg-success-bg px-[7px] py-0.5 text-[11px] font-bold text-success">
									Vérifié
								</span>
							)}
						</div>
						<div class="hidden min-w-0 text-body-sm text-text-muted sm:block">{product.supplier}</div>
						<div class="text-tabular text-right text-body-sm font-semibold text-text-primary">{product.price}</div>
						<div class="text-tabular text-right text-body-sm text-text-muted">{product.moq}</div>
					</div>
				))
			}
		</div>
	</div>
</div>
