---
import { Image } from 'astro:assets'
import toteBagCoton from '../assets/images/mo2197-09.jpg'
import sacIsotherme from '../assets/images/impr_1515772-PDP_12.webp'
import serviettePlage from '../assets/images/mo2059-12.jpg'

const tags = ['Matière recyclée', 'Certifié GRS', 'Stock Europe']

const products = [
  { name: 'Sac tote coton bio 220g', verified: true, supplier: 'EcoBag Fabrics', price: '2,10 €', moq: '250', image: toteBagCoton, focus: 'center' },
  { name: 'Sac isotherme polyester recyclé', verified: true, supplier: 'Nordic Print', price: '6,90 €', moq: '100', image: sacIsotherme, focus: 'center' },
  { name: 'Serviette de plage recyclée', verified: false, supplier: 'Textilia Iberia', price: '4,50 €', moq: '150', image: serviettePlage, focus: 'center' },
]
---

<div
	data-reveal
	class="anim-float relative mx-auto max-w-[880px] overflow-hidden rounded-xl border border-hairline bg-card text-left shadow-elevation-3"
	role="img"
	aria-label="Aperçu de la recherche promotionalsourcing.eu/recherche : un sac tote en coton bio, un sac isotherme en polyester recyclé et une serviette de plage recyclée, filtrés par matière recyclée, certification GRS et stock Europe, avec fournisseur, prix et quantité minimale de commande."
>
	<div aria-hidden="true">
		<div class="flex items-center gap-1.5 border-b border-hairline bg-sunken px-[18px] py-3.5">
			<span class="h-[9px] w-[9px] rounded-full bg-ink-200"></span>
			<span class="h-[9px] w-[9px] rounded-full bg-ink-200"></span>
			<span class="h-[9px] w-[9px] rounded-full bg-ink-200"></span>
			<span class="ml-3 text-caption text-text-muted">promotionalsourcing.eu/recherche</span>
		</div>
		<div class="px-6 py-5">
			<div class="mb-4 flex flex-wrap gap-2">
				{
					tags.map((tag, i) => (
						<span
							class={`rounded-pill px-[11px] py-[5px] text-caption font-semibold ${i === 0 ? 'bg-brand-subtle text-indigo-600' : 'bg-ink-100 text-ink-600'}`}
						>
							{tag}
						</span>
					))
				}
			</div>
			<div class="grid grid-cols-[44px_minmax(0,1fr)_64px_54px] items-center gap-2 border-b border-hairline py-2.5 text-caption font-bold uppercase tracking-wide text-text-muted sm:grid-cols-[56px_minmax(0,1fr)_110px_90px_80px] sm:gap-3">
				<div></div>
				<div>Produit</div>
				<div class="hidden sm:block">Fournisseur</div>
				<div class="text-right">Prix</div>
				<div class="text-right">MOQ</div>
			</div>
			{
				products.map((product, i) => (
					<div
						class={`grid grid-cols-[44px_minmax(0,1fr)_64px_54px] items-center gap-2 py-3 sm:grid-cols-[56px_minmax(0,1fr)_110px_90px_80px] sm:gap-3 ${i < products.length - 1 ? 'border-b border-hairline' : ''}`}
					>
						<div class="h-11 w-11 overflow-hidden rounded-sm sm:h-14 sm:w-14">
							<Image
								src={product.image}
								alt={product.name}
								width={56}
								height={56}
								class="h-full w-full object-cover"
								style={`object-position: ${product.focus};`}
							/>
						</div>
						<div class="min-w-0 text-body-sm font-semibold text-text-primary">
							{product.name}
							{product.verified && (
								<span class="ml-1.5 rounded-pill bg-success-bg px-[7px] py-0.5 text-[11px] font-bold text-success">
									Vérifié
								</span>
							)}
						</div>
						<div class="hidden min-w-0 text-body-sm text-text-muted sm:block">{product.supplier}</div>
						<div class="text-tabular text-right text-body-sm font-semibold text-text-primary">{product.price}</div>
						<div class="text-tabular text-right text-body-sm text-text-muted">{product.moq}</div>
					</div>
				))
			}
		</div>
	</div>
</div>
