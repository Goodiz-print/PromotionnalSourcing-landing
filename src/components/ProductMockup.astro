---
import { Image } from 'astro:assets'
import toteBagCoton from '../assets/images/mo2197-09.jpg'
import sacIsotherme from '../assets/images/impr_1515772-PDP_12.webp'
import serviettePlage from '../assets/images/mo2059-12.jpg'
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)

const tags = t('productMockup.tags')
const productLabels = t('productMockup.products')

const products = [
  { ...productLabels[0], verified: true, price: '2,10', image: toteBagCoton, focus: 'center' },
  { ...productLabels[1], verified: true, price: '6,90', image: sacIsotherme, focus: 'center' },
  { ...productLabels[2], verified: false, price: '4,50', image: serviettePlage, focus: 'center' },
]
---

<div
	data-reveal
	class="anim-float relative w-full rounded-[20px] bg-card p-[26px] text-left shadow-elevation-3"
	role="img"
	aria-label={t('productMockup.ariaLabel')}
>
	<div aria-hidden="true">
		<div class="mb-3.5 flex items-center gap-3 rounded-xl border-2 border-hairline px-4 py-3">
			<span class="flex-1 truncate text-body-sm font-medium text-text-primary">{products[0].name}</span>
			<span class="anim-caret h-[15px] w-0.5 shrink-0 bg-indigo-500"></span>
			<span
				class="shrink-0 rounded-pill px-3 py-1.5 text-[11px] font-extrabold tracking-wide text-white"
				style="background: linear-gradient(100deg, var(--indigo-500), #7a3fd4);"
			>
				✦ {t('productMockup.aiChip')}
			</span>
		</div>
		<div class="mb-[18px] flex flex-wrap gap-2">
			{
				tags.map((tag) => (
					<span class="rounded-pill bg-brand-subtle px-3 py-1.5 text-caption font-semibold text-indigo-600">{tag}</span>
				))
			}
		</div>
		{
			products.map((product, i) => (
				<div class={`flex items-center gap-3.5 rounded-xl border border-hairline p-3 ${i < products.length - 1 ? 'mb-2.5' : ''}`}>
					<div class="h-[50px] w-[38px] shrink-0 overflow-hidden rounded-md">
						<Image
							src={product.image}
							alt={product.name}
							width={56}
							height={70}
							class="h-full w-full object-cover"
							style={`object-position: ${product.focus};`}
						/>
					</div>
					<div class="min-w-0 flex-1">
						<p class="truncate text-body-sm font-semibold text-text-primary">{product.name}</p>
						<p class="truncate text-caption text-text-muted">
							{product.verified ? t('productMockup.verifiedLabel') : t('productMockup.supplierLabel')} · {product.country}
						</p>
					</div>
					<p class="text-tabular shrink-0 text-body-sm font-bold text-indigo-600">
						{t('productMockup.priceFrom')} {product.price} {t('productMockup.priceSuffix')}
					</p>
				</div>
			))
		}
		<div class="mt-3.5 flex items-center justify-between text-caption text-text-muted">
			<span>{t('productMockup.footerCompare')}</span>
			<span class="font-bold text-amber-600">{t('productMockup.footerFlag')}</span>
		</div>
	</div>
</div>
