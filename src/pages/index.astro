---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import LogoStrip from '../components/LogoStrip.astro'
import ProblemSection from '../components/ProblemSection.astro'
import FeaturesGrid from '../components/FeaturesGrid.astro'
import StatsBand from '../components/StatsBand.astro'
import HowItWorks from '../components/HowItWorks.astro'
import AudienceSplit from '../components/AudienceSplit.astro'
import FinalCta from '../components/FinalCta.astro'
import { useTranslations } from '../i18n/utils'

const t = useTranslations(Astro.currentLocale)
---

<Layout title={t('seo.title')} description={t('seo.description')}>
	<Hero />
	<LogoStrip />
	<ProblemSection />
	<FeaturesGrid />
	<StatsBand />
	<HowItWorks />
	<AudienceSplit />
	<FinalCta />
</Layout>
